{
  "name": "locket-dapp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "blockchain:compile": "hardhat compile",
    "blockchain:deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "blockchain:deploy:proof:sepolia": "hardhat run scripts/deploy-proof-registry.js --network sepolia",
    "blockchain:deploy:collectible:sepolia": "hardhat run scripts/deploy-collectible-moment.js --network sepolia",
    "blockchain:deploy:milestone:sepolia": "hardhat run scripts/deploy-friendship-milestone.js --network sepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.15"
  }
}
